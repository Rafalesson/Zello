
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum DoctorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConsultationStatus {
  AGENDADA
  CANCELADA
  REALIZADA
  EM_ESPERA
  EM_ANDAMENTO
  NAO_REALIZADA
}

model Address {
  id              Int            @id @default(autoincrement())
  street          String
  number          String
  complement      String?
  neighborhood    String
  city            String
  state           String
  zipCode         String
  doctorProfiles  DoctorProfile[]
  patientProfiles PatientProfile[]
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  phone                String?               @unique
  password             String
  role                 Role
  name                 String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isActive             Boolean               @default(true)
  passwordResetToken   String?               @unique
  passwordResetExpires DateTime?
  doctorProfile        DoctorProfile?
  patientProfile       PatientProfile?
  issuedCertificates   MedicalCertificate[]  @relation("DoctorCertificates")
  receivedCertificates MedicalCertificate[]  @relation("PatientCertificates")
  issuedPrescriptions   MedicalPrescription[] @relation("DoctorPrescriptions")
  receivedPrescriptions MedicalPrescription[] @relation("PatientPrescriptions")
}

model DoctorProfile {
  id                Int            @id @default(autoincrement())
  name              String
  crm               String         @unique
  specialty         String?
  bio               String?
  profilePictureUrl String?
  status            DoctorStatus   @default(PENDING)
  address           Address?       @relation(fields: [addressId], references: [id])
  addressId         Int?           @unique
  phone             String?
  consultationPrice Float?
  user              User           @relation(fields: [userId], references: [id])
  userId            Int            @unique
  availabilities    Availability[]
  appointments      Appointment[]
}

model Availability {
  id                  Int           @id @default(autoincrement())
  dayOfWeek           Int           // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime           String        // HH:mm format
  endTime             String        // HH:mm format
  slotDurationMinutes Int           @default(30)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  doctorProfile       DoctorProfile @relation(fields: [doctorProfileId], references: [id])
  doctorProfileId     Int

  @@unique([doctorProfileId, dayOfWeek, startTime])
  @@index([doctorProfileId])
}

model PatientProfile {
  id          Int      @id @default(autoincrement())
  name        String
  cpf         String   @unique
  dateOfBirth DateTime
  sex         Sex?
  phone       String?
  user        User     @relation(fields: [userId], references: [id])
  userId      Int      @unique
  address     Address? @relation(fields: [addressId], references: [id])
  addressId   Int?     @unique
  appointments Appointment[]
}

model MedicalCertificate {
  id             Int       @id @default(autoincrement())
  code           String    @unique @default(cuid())
  issueDate      DateTime  @default(now())
  templateId     String    @default("default")
  purpose        String
  startDate      DateTime?
  durationInDays Int?
  cidCode        String?
  cidDescription String?
  observations   String?
  pdfUrl         String?
  doctor         User      @relation("DoctorCertificates", fields: [doctorId], references: [id])
  doctorId       Int
  patient        User      @relation("PatientCertificates", fields: [patientId], references: [id])
  patientId      Int
}

model MedicalPrescription {
  id             Int      @id @default(autoincrement())
  code           String   @unique @default(cuid())
  issueDate      DateTime @default(now())
  templateId     String   @default("default")
  items          Json
  generalGuidance String?
  additionalNotes String?
  pharmacyToken   String?
  patientToken    String?
  pdfUrl          String?
  doctor         User     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  doctorId       Int
  patient        User     @relation("PatientPrescriptions", fields: [patientId], references: [id])
  patientId      Int
}
model CidCode {
  id          Int    @id @default(autoincrement())
  code        String @unique
  description String

  @@index([code])
}

enum SymptomDuration {
  HOJE
  ONTEM
  ESTA_SEMANA
  MAIS_DE_UMA_SEMANA
}

model Appointment {
  id               Int                @id @default(autoincrement())
  doctorProfile    DoctorProfile      @relation(fields: [doctorProfileId], references: [id])
  doctorProfileId  Int
  patientProfile   PatientProfile     @relation(fields: [patientProfileId], references: [id])
  patientProfileId Int
  date             DateTime
  status           ConsultationStatus @default(AGENDADA)
  cancellationReason String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  preTriage        PreTriage?
  consentRecord    ConsentRecord?

  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@unique([doctorProfileId, date])
}

model PreTriage {
  id            Int              @id @default(autoincrement())
  symptoms      String           @db.VarChar(500)
  duration      SymptomDuration
  intensity     Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  appointment   Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId Int              @unique
}

model ConsentRecord {
  id            Int         @id @default(autoincrement())
  accepted      Boolean
  ipAddress     String?
  userAgent     String?
  termsVersion  String      @default("v1.0")
  acceptedAt    DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId Int         @unique
}

model LegalTerms {
  id        Int      @id @default(autoincrement())
  version   String   @unique
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

