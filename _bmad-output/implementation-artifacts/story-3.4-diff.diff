+    expect(ConsultationStatus.NAO_REALIZADA).toBe('NAO_REALIZADA');
+  });
+
+  it('should have exactly 6 statuses', () => {
+    const values = Object.values(ConsultationStatus);
+    expect(values).toHaveLength(6);
+  });
+});
